# =============================================================================
# Scraping — Chrome, profile, JobRight / Glassdoor / ZipRecruiter
# =============================================================================

CHROME_APP_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# Dedicated scraping profile (omit to use <repo>/zata/chromeData/irangarick)
SCRAPING_CHROME_DIR=C:\\Users\\location\\Desktop\\Chennu-Job-Viewer\\zata\\irangarick
SCRAPING_PORT=9003

DATA_DIR=zata

# Comma- or pipe-separated keywords; scrapers run sequential phases per keyword.
SCRAPER_SEARCH_KEYWORDS=devops, cloud engineer, site reliability engineer, database administrator, platform engineer

# LinkedIn Jobs (`eLinkedIn.py`) — same keywords as above; location for built-in search URLs
LINKEDIN_JOBS_LOCATION=United States
# LINKEDIN_SCROLL_MAX_ROUNDS=45
# LinkedIn only: ~10–15 pages/keyword is usually enough (~250–400 listings); raise if needed.
LINKEDIN_MAX_SEARCH_PAGES=12
LINKEDIN_RESULTS_PAGE_SIZE=25
LINKEDIN_PAGE_LOAD_PAUSE_SEC=1.2
LINKEDIN_PAGINATION_WAIT_SEC=28
# LINKEDIN_MAX_DETAIL_JOBS=120

SCRAPING_STALE_RETRIES=3
SCRAPING_STALE_DELAY=0.85

SCRAPING_HEADLESS=0
CLOSE_ON_COMPLETE=1
# Optional: normal | eager | none. Default for undetected Chrome is eager (avoids driver.get() hanging on SPAs).
# SCRAPING_PAGE_LOAD_STRATEGY=eager

# =============================================================================
# Database & Midhtech — job storage (MongoDB), MAAS login (dValidate / suggest)
# =============================================================================
#
# Primary store for scrapers + dValidate: JOB_STORAGE_BACKEND=sqlite OR mongo (default mongo).
# When sqlite: SQLITE_JOBS_PATH (default zata/chennu_jobs.sqlite). Seed/copy from Mongo:
#   python scripts/mongo_to_sqlite.py -o zata/chennu_jobs.sqlite
# Mongo URI remains required for that export script and for JOB_STORAGE_BACKEND=mongo.

JOB_STORAGE_BACKEND=mongo
# SQLITE_JOBS_PATH=zata/chennu_jobs.sqlite

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority&appName=ChennuJobViewer
MONGODB_DATABASE=chennuJobViewer

MIDHTECH_EMAIL=your-email@example.com
MIDHTECH_PASSWORD=your-password

# =============================================================================
# chennu.co — push APPLY jobs to the consulting platform (fPushToConsulting.py)
# =============================================================================
#
# HARVEST_PUSH_SECRET: copy from the .env on the server running chennu.co
#   (the value of HARVEST_PUSH_SECRET in that Django app's environment)
#
# CONSULTING_API_URL: base URL of the consulting platform (no trailing slash)
#   Default is https://chennu.co — only change if running locally or on staging.
#
# One-time setup in chennu.co Django admin before first push:
#   Harvest → Job Board Platforms → Add:
#     slug=linkedin,     name=LinkedIn
#     slug=ziprecruiter, name=ZipRecruiter
#     slug=glassdoor,    name=GlassDoor
#     slug=jobright,     name=JobRight

HARVEST_PUSH_SECRET=get-this-from-chennu-co-server-env
# CONSULTING_API_URL=https://chennu.co
